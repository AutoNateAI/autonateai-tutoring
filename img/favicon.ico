<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
  <defs>
    <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3578e5;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#25c2a0;stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- Background Circle for a professional look -->
  <circle cx="50" cy="50" r="48" fill="none" stroke="url(#logoGrad)" stroke-width="2" />
  
  <!-- Stylized 'A' built from nodes and paths -->
  <path d="M50 20 L25 80 L35 80 L50 55 L65 80 L75 80 Z" fill="url(#logoGrad)" />
  <circle cx="50" cy="20" r="4" fill="#3578e5" />
  <circle cx="25" cy="80" r="4" fill="#25c2a0" />
  <circle cx="75" cy="80" r="4" fill="#25c2a0" />
  <circle cx="50" cy="55" r="4" fill="#3578e5" />
  
  <!-- Connecting bridge -->
  <rect x="40" y="65" width="20" height="3" fill="white" />
</svg>
